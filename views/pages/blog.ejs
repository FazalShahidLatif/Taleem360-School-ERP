<%- include('../partials/header') %>

<section class="hero blog-hero">
    <div class="container">
        <h1 class="hero-title">Taleem<span>360</span> Blog</h1>
        <p class="hero-subtitle">Insights, tutorials, and news about the future of AI education in Pakistan.</p>
    </div>
</section>

<section class="blog-grid section">
    <div class="container">
        <div class="grid grid-3">
            <% posts.forEach(post => { %>
                <article class="card blog-card" id="post-<%= post.id %>">
                    <div class="card-image">
                        <img src="<%= post.image %>" alt="<%= post.title %>" loading="lazy">
                        <span class="card-badge"><%= post.category %></span>
                    </div>
                    <div class="card-content">
                        <div class="post-meta">
                            <span class="post-date"><%= post.date %></span>
                            <span class="post-author">By <%= post.author %></span>
                        </div>
                        <h2 class="card-title"><a href="/blog/<%= post.slug %>"><%= post.title %></a></h2>
                        <p class="card-text"><%= post.excerpt %></p>
                        <a href="/blog/<%= post.slug %>" class="btn-text">Read Article →</a>
                    </div>
                </article>
            <% }) %>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
