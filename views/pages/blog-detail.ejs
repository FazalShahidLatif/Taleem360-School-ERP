<%- include('../partials/header') %>

<article class="blog-post-detail">
    <header class="post-header">
        <div class="container container-narrow">
            <nav class="breadcrumb">
                <a href="/">Home</a> / <a href="/blog">Blog</a> / <span><%= post.title %></span>
            </nav>
            <span class="post-category"><%= post.category %></span>
            <h1 class="post-title"><%= post.title %></h1>
            <div class="post-meta-detailed">
                <div class="author-info">
                    <div class="author-avatar"><%= post.author.charAt(0) %></div>
                    <div>
                        <span class="author-name"><%= post.author %></span>
                        <span class="post-date"><%= post.date %></span>
                    </div>
                </div>
                <div class="post-share">
                    <span>Share:</span>
                    <a href="#" onclick="window.open('https://twitter.com/intent/tweet?text=<%= encodeURIComponent(post.title) %>&url=' + window.location.href)" aria-label="Share on Twitter">𝕏</a>
                    <a href="#" onclick="window.open('https://www.facebook.com/sharer/sharer.php?u=' + window.location.href)" aria-label="Share on Facebook">f</a>
                </div>
            </div>
        </div>
    </header>

    <div class="post-featured-image">
        <div class="container">
            <img src="<%= post.image %>" alt="<%= post.title %>">
        </div>
    </div>

    <div class="post-body">
        <div class="container container-narrow">
            <div class="post-content">
                <%- post.content %>
            </div>
            
            <footer class="post-footer">
                <div class="post-tags">
                    <span>Tags:</span>
                    <a href="#">#AI</a> <a href="#">#Pakistan</a> <a href="#">#EdTech</a> <a href="#">#Future</a>
                </div>
                
                <div class="post-navigation">
                    <a href="/blog" class="btn btn-outline">← Back to Blog</a>
                </div>
            </footer>
        </div>
    </div>
</article>

<section class="related-posts section bg-light">
    <div class="container">
        <h2 class="section-title">Continue Reading</h2>
        <div class="grid grid-3">
            <% related.forEach(rel => { %>
                <article class="card blog-card">
                    <div class="card-image">
                        <img src="<%= rel.image %>" alt="<%= rel.title %>">
                    </div>
                    <div class="card-content">
                        <h3 class="card-title-sm"><a href="/blog/<%= rel.slug %>"><%= rel.title %></a></h3>
                        <a href="/blog/<%= rel.slug %>" class="btn-text">Read More →</a>
                    </div>
                </article>
            <% }) %>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
