<%- include('../partials/header') %>

<!-- Hero -->
<section class="hero">
    <div class="hero-grid"></div>
    <div class="hero-visual"></div>
    <div class="container">
        <div class="hero-content">
            <div class="hero-badge"><span class="dot"></span> Pakistan's #1 School ERP</div>
            <h1>Smart <span class="highlight">School ERP</span> with <span class="gold">AI Learning</span> Built In</h1>
            <p class="hero-desc">Complete educational management — attendance, fees, exams, timetables — plus AI-powered learning modules aligned with Pakistan's national curriculum.</p>
            <div class="hero-actions">
                <a href="/courses" class="btn-hero btn-hero-primary">Explore Modules →</a>
                <a href="/login" class="btn-hero btn-hero-outline">Get Started Free</a>
            </div>
            <div class="hero-stats">
                <div><div class="hero-stat-num"><%= stats.totalCourses %></div><div class="hero-stat-label">Modules</div></div>
                <div><div class="hero-stat-num"><%= stats.totalLessons %>+</div><div class="hero-stat-label">Lessons</div></div>
                <div><div class="hero-stat-num"><%= stats.freeCourses %></div><div class="hero-stat-label">Free Courses</div></div>
            </div>
        </div>
    </div>
</section>

<!-- Core ERP Features -->
<section class="section" id="features">
    <div class="container">
        <div class="section-header fade-up">
            <span class="section-tag">Core Platform</span>
            <h2>Everything Your School Needs</h2>
            <p>A complete ERP ecosystem that digitizes every aspect of school administration — from enrollment to graduation.</p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:28px;">
            <div class="card fade-up">
                <div class="card-icon indigo">🏫</div>
                <h3>Student Management</h3>
                <p>Enrollment, profiles, attendance tracking, and parent communication — all in one unified system.</p>
            </div>
            <div class="card fade-up">
                <div class="card-icon emerald">💰</div>
                <h3>Fee & Finance</h3>
                <p>Fee collection, challan generation, payroll, and financial reporting with JazzCash/EasyPaisa integration.</p>
            </div>
            <div class="card fade-up">
                <div class="card-icon amber">📝</div>
                <h3>Exam & Grading</h3>
                <p>Automated exam scheduling, mark entry, grade computation, and board-compliant result cards.</p>
            </div>
        </div>
    </div>
</section>

<!-- Feature Rows -->
<section class="section" style="padding-top:0;">
    <div class="container">
        <div class="feature-row fade-up">
            <div class="feature-img">🏫</div>
            <div class="feature-text">
                <span class="feature-tag" style="background:rgba(0,212,255,0.1);color:var(--accent);">School ERP Core</span>
                <h3>Complete Digital Administration</h3>
                <p>Designed for Pakistani schools and colleges. Manage students, staff, finance, timetables, and examinations from a single dashboard. Fully compliant with EMIS and education board requirements.</p>
                <a href="/courses" class="link-arrow">View ERP Modules →</a>
            </div>
        </div>
        <div class="feature-row reverse fade-up">
            <div class="feature-img" style="background:linear-gradient(135deg,#1a3a6b,#0c1e3d);">🤖</div>
            <div class="feature-text">
                <span class="feature-tag" style="background:rgba(255,204,0,0.12);color:#d97706;">AI Learning Addon</span>
                <h3>AI Curriculum Aligned to 10th Grade</h3>
                <p>Synchronized with Pakistan's National AI Framework. From foundational AI concepts to professional freelancing — practical skills that translate into real-world earning.</p>
                <a href="/courses" class="link-arrow">Explore AI Courses →</a>
            </div>
        </div>
        <div class="feature-row fade-up">
            <div class="feature-img" style="background:linear-gradient(135deg,#059669,#047857);">🌍</div>
            <div class="feature-text">
                <span class="feature-tag" style="background:rgba(16,185,129,0.1);color:#059669;">Community Uplift</span>
                <h3>AI for Social Impact</h3>
                <p>Empowering local communities to solve their own challenges. Our AI hub provides tools for community leaders to implement practical AI solutions across Pakistan.</p>
                <a href="/about" class="link-arrow">Learn More →</a>
            </div>
        </div>
    </div>
</section>

<!-- Featured Courses -->
<section class="section" style="background:#fff;">
    <div class="container">
        <div class="section-header fade-up">
            <span class="section-tag">Modules & Courses</span>
            <h2>Featured Learning Paths</h2>
            <p>ERP training modules and AI addons — everything your institution needs to thrive in the digital age.</p>
        </div>
        <div class="courses-grid">
            <% featured.forEach(function(course) { %>
            <div class="course-card fade-up">
                <div class="course-card-body">
                    <div class="course-card-top">
                        <span class="course-icon"><%= course.icon %></span>
                        <span class="course-badge <%= course.isFree ? 'badge-free' : 'badge-pro' %>"><%= course.isFree ? 'Free' : 'Pro' %></span>
                    </div>
                    <h3><%= course.title %></h3>
                    <p><%= course.description.substring(0, 120) %>...</p>
                    <div class="course-meta-row">
                        <span>📚 <%= course.lessons %> lessons</span>
                        <span>⏱ <%= course.duration %></span>
                    </div>
                </div>
                <div class="course-card-footer">
                    <span class="course-level"><%= course.level %></span>
                    <a href="/courses/<%= course.slug %>" class="course-link">View Module →</a>
                </div>
            </div>
            <% }); %>
        </div>
        <div style="text-align:center;margin-top:48px;" class="fade-up">
            <a href="/courses" class="btn-hero btn-hero-primary" style="display:inline-flex;">View All Modules →</a>
        </div>
    </div>
</section>

<!-- Pricing -->
<section class="section pricing-section" id="pricing">
    <div class="container">
        <div class="section-header fade-up">
            <span class="section-tag" style="background:rgba(0,212,255,0.12);">Pricing</span>
            <h2>Choose Your Journey</h2>
            <p>Fuel your institution's growth and choose the tier that fits your goals.</p>
        </div>
        <div class="pricing-grid">
            <div class="pricing-card fade-up">
                <h3>Student Starter</h3>
                <div class="pricing-price" style="color:var(--accent);">Free</div>
                <ul>
                    <li>Basic ERP Dashboard</li>
                    <li>3 Free Course Modules</li>
                    <li>NotebookLM Workshops</li>
                    <li>Progress Tracking</li>
                </ul>
                <a href="/login" class="btn-pricing btn-pricing-ghost">Join for Free</a>
            </div>
            <div class="pricing-card featured fade-up">
                <span class="popular-tag">Most Popular</span>
                <h3>AI Pro Individual</h3>
                <div class="pricing-price">$49<span style="font-size:1rem;opacity:0.6;">/yr</span></div>
                <ul>
                    <li>Complete ERP Access</li>
                    <li>All AI Course Modules</li>
                    <li>Earning & Freelancing Pack</li>
                    <li>Priority Support</li>
                    <li>SaaSSkul Masterclass</li>
                </ul>
                <a href="https://saasskul.com" class="btn-pricing btn-pricing-primary">Get Pro Access</a>
            </div>
            <div class="pricing-card fade-up">
                <h3>Community Leader</h3>
                <div class="pricing-price">$199<span style="font-size:1rem;opacity:0.6;">/yr</span></div>
                <ul>
                    <li>White Label Licenses</li>
                    <li>Community Uplift Toolkit</li>
                    <li>Local Branch Support</li>
                    <li>Unlimited Users</li>
                </ul>
                <a href="#" class="btn-pricing btn-pricing-ghost">Contact Us</a>
            </div>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
