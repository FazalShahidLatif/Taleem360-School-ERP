<%- include('../partials/header') %>

<section class="section" style="background: var(--bg-body); padding-top: 140px;">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Learning Catalog</span>
            <h2>Explore Our Modules</h2>
            <p>From core ERP training to advanced AI curriculum, choose the path that fits your institutional goals.</p>
        </div>

        <div class="tab-bar">
            <button class="tab-btn active" data-category="all">All Modules</button>
            <button class="tab-btn" data-category="AI Learning">AI Learning</button>
            <button class="tab-btn" data-category="ERP Training">ERP Training</button>
            <button class="tab-btn" data-category="Economic Empowerment">Earning</button>
            <button class="tab-btn" data-category="Community Uplift">Community</button>
        </div>

        <div class="courses-grid" id="courses-grid">
            <% courses.forEach(function(course) { %>
            <div class="course-card-wrap fade-up visible" data-category="<%= course.category %>">
                <div class="course-card">
                    <div class="course-card-body">
                        <div class="course-card-top">
                            <span class="course-icon"><%= course.icon %></span>
                            <span class="course-badge <%= course.isFree ? 'badge-free' : 'badge-pro' %>"><%= course.isFree ? 'Free' : 'Pro' %></span>
                        </div>
                        <h3><%= course.title %></h3>
                        <p><%= course.description %></p>
                        <div class="course-meta-row">
                            <span>📚 <%= course.lessons %> lessons</span>
                            <span>⏱ <%= course.duration %></span>
                        </div>
                    </div>
                    <div class="course-card-footer">
                        <span class="course-level"><%= course.level %></span>
                        <a href="/courses/<%= course.slug %>" class="course-link">View Module →</a>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
