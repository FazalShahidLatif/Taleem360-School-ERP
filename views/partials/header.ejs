<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Taleem360 — School ERP & AI Learning' %></title>
    <meta name="description" content="<%= typeof metaDesc !== 'undefined' ? metaDesc : 'Taleem360 School ERP — Pakistan\'s premier educational management platform with AI-powered learning modules.' %>">
    <meta name="author" content="SaaSSkul">
    <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'Taleem360 School ERP' %>">
    <meta property="og:description" content="Pakistan's premier School ERP with AI-powered learning addons.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://taleem360.online">
    <link rel="stylesheet" href="/css/main.css">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "EducationalOrganization",
      "name": "Taleem360 School ERP",
      "url": "https://taleem360.online",
      "description": "Pakistan's premier educational ERP platform with AI-powered learning modules.",
      "sameAs": ["https://saasskul.com"]
    }
    </script>
</head>
<body>
    <nav class="nav" id="main-nav">
        <div class="nav-inner">
            <a href="/" class="nav-brand">
                <div class="nav-logo">T</div>
                <span class="nav-title">Taleem<span>360</span></span>
            </a>
            <div class="nav-links" id="nav-links">
                <a href="/" class="<%= typeof currentPage !== 'undefined' && currentPage === 'home' ? 'active' : '' %>">Home</a>
                <a href="/courses" class="<%= typeof currentPage !== 'undefined' && currentPage === 'courses' ? 'active' : '' %>">Courses</a>
                <a href="/blog" class="<%= typeof currentPage !== 'undefined' && currentPage === 'blog' ? 'active' : '' %>">Blog</a>
                <a href="/about" class="<%= typeof currentPage !== 'undefined' && currentPage === 'about' ? 'active' : '' %>">About</a>
                <% if (user) { %>
                    <a href="/dashboard" class="btn-nav-outline">Dashboard</a>
                    <a href="/auth/logout" class="btn-nav">Logout</a>
                <% } else { %>
                    <a href="/login" class="btn-nav-outline">Sign In</a>
                    <a href="/login" class="btn-nav">Get Started</a>
                <% } %>
            </div>
            <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">
                <span></span><span></span><span></span>
            </button>
        </div>
    </nav>
